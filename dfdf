    .admin-profile {
      display: flex;
      align-items: center;
      gap: 20px;
      border-bottom: 1px solid #ddd;
      padding-bottom: 20px;
      margin-bottom: 30px;
    }

    .profile-pic {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      border: 3px solid #0d6efd;
      object-fit: cover;
    }

    .profile-info h3 {
      margin: 0;
    }

    .section-header {
      font-size: 1.25rem;
      font-weight: 600;
      color: #0d6efd;
      margin-top: 40px;
      margin-bottom: 20px;
    }

    .alert-danger.blink {
      animation: blinker 1.2s ease-in-out infinite;
      font-weight: 600;
      text-align: center;
      border: 2px solid #dc3545;
      font-size: 14px;
      background: #fff5f5;
      border-radius: 8px;
      padding: 10px;
      margin-top: 20px;
    }

    @keyframes blinker {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    .btn-main {
      background-color: #0d6efd;
      color: white;
      border-radius: 8px;
      padding: 10px 24px;
      transition: background 0.3s;
    }

    .btn-main:hover {
      background-color: #0b5ed7;
    }

    .list-group-item {
      padding: 12px 20px;
      border: none;
      border-bottom: 1px solid #eee;
    }

    .list-group-item:last-child {
      border-bottom: none;
    }

    .btn-sm {
      margin-left: 10px;
    }
  </style>
</head>
<body>
  <div class="container-wrapper">
    <div class="admin-profile">
      <img src="<?= htmlspecialchars($admin['profile_pic']) ?>" class="profile-pic" alt="Admin Profile Picture">
      <div class="profile-info">
        <h3><?= htmlspecialchars($admin['name']) ?></h3>
        <p class="text-muted mb-1"><?= htmlspecialchars($admin['hospital_name']) ?></p>
        <p><strong>County:</strong> <?= htmlspecialchars($admin['county']) ?></p>
        <small class="text-secondary">Access Code: <?= htmlspecialchars($admin['access_code']) ?></small>
      </div>
    </div>

    <div id="alert-area"></div>

    <div class="section-header">🚑 Ambulance Requests</div>
    <ul class="list-group">
      <!-- Dynamic ambulance requests here -->
    </ul>

    <div class="section-header">🛌 Emergency Room Requests</div>
    <ul class="list-group">
      <!-- Dynamic emergency room requests here -->
    </ul>

    <div class="d-flex justify-content-between flex-wrap gap-3 mt-4">
      <div>
        <h6>Manage Ambulances</h6>
        <button class="btn-main" data-bs-toggle="modal" data-bs-target="#ambulanceModal">Add Ambulance</button>
      </div>
      <div>
        <h6>Manage Emergency Rooms</h6>
        <button class="btn-main" data-bs-toggle="modal" data-bs-target="#roomModal">Add Room</button>
      </div>
      <div>
        <h6>Logout</h6>
        <a href="logout.php" class="btn btn-danger">Logout</a>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let pendingRequests = [];

    function speak(text) {
      const msg = new SpeechSynthesisUtterance(text);
      msg.lang = 'en-US';
      window.speechSynthesis.speak(msg);
    }

    function addAlertUI(request) {
      const alertId = `alert-${request.type}-${request.name}`;
      if (document.getElementById(alertId)) return;

      const alertDiv = document.createElement("div");
      alertDiv.id = alertId;
      alertDiv.className = "alert alert-danger blink";
      alertDiv.innerText = `🚨 Pending ${request.type} request from ${request.name}`;

      document.getElementById("alert-area").appendChild(alertDiv);
    }

    function updateRequests() {
      fetch(`check_requests.php?hospital=<?= urlencode($admin['hospital_name']) ?>`)
        .then(res => res.json())
        .then(data => {
          data.forEach(req => {
            const id = `${req.type}-${req.name}`;
            if (!pendingRequests.includes(id)) {
              pendingRequests.push(id);
              speak(`New ${req.type} request from ${req.name}`);
              addAlertUI(req);
            }
          });
        });
    }

    document.addEventListener("mousemove", () => {
      pendingRequests.forEach(id => {
        const [type, name] = id.split("-");
        speak(`Reminder: ${type} request from ${name}`);
      });
    });

    setInterval(updateRequests, 5000);
  </script>
</body>
</html>
